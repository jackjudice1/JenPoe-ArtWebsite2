# Copy this file to .env.local and fill in real values before wiring up
# payments/email. Nothing in the app reads these yet — they're placeholders
# for the integrations described in README.md.

# Stripe (checkout + payments)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Contact form + newsletter email delivery (pick one provider)
RESEND_API_KEY=
MAILCHIMP_API_KEY=
MAILCHIMP_AUDIENCE_ID=

# Site URL (used for metadata/OG tags in production)
NEXT_PUBLIC_SITE_URL=https://www.lacquerandivory.com
