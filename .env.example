# Copy this file to .env.local and fill in real values before wiring up
# payments/email. See README.md for setup details on each integration.

# Stripe (checkout + payments) — not yet wired up
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend (contact form email — required for app/api/contact/route.ts to work)
RESEND_API_KEY=
# Sender address. Until a domain is verified in Resend, this must stay
# "onboarding@resend.dev" — a custom address will fail to send.
RESEND_FROM_ADDRESS=onboarding@resend.dev

# Newsletter signup — not yet wired up
MAILCHIMP_API_KEY=
MAILCHIMP_AUDIENCE_ID=

# Site URL (used for metadata/OG tags in production)
NEXT_PUBLIC_SITE_URL=https://www.lacquerandivory.com
